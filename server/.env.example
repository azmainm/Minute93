# ===== Application =====
NODE_ENV=development
PORT=3000
API_PREFIX=api

# ===== Database (PostgreSQL) =====
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_URL=postgresql://...

# ===== Authentication =====
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ===== API-Football =====
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Active leagues (comma-separated API-Football league IDs)
# PL=39, La Liga=140, Champions League=2, World Cup=1
ACTIVE_LEAGUES=39,140,2

# Polling intervals (milliseconds)
POLL_INTERVAL_LIVE=30000
POLL_INTERVAL_IDLE=300000

# ===== Upstash Kafka =====
UPSTASH_KAFKA_REST_URL=https://your-kafka-instance.upstash.io
UPSTASH_KAFKA_REST_USERNAME=your-kafka-username
UPSTASH_KAFKA_REST_PASSWORD=your-kafka-password
KAFKA_TOPIC=match.events

# ===== Upstash Redis =====
REDIS_URL=redis://default:your-redis-password@your-redis-instance.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token

# ===== Rate Limiting =====
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL=900000
AUTH_THROTTLE_LIMIT=3

# ===== IP Geolocation =====
IP_GEOLOCATION_URL=http://ip-api.com/json

# ===== Grafana Cloud (Phase 4) =====
# PROMETHEUS_REMOTE_WRITE_URL=https://prometheus-prod.grafana.net/api/prom/push
# GRAFANA_API_KEY=your-grafana-api-key
# GRAFANA_CLOUD_URL=https://yourname.grafana.net

# ===== Frontend URL (for CORS) =====
CLIENT_URL=http://localhost:3001
