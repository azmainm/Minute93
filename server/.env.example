# ===== Application =====
NODE_ENV=development
PORT=3000

# ===== Database (PostgreSQL) =====
# Local: docker compose provides postgres:16 on port 5432
# Production: Render Postgres internal connection string
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=dev
DATABASE_NAME=minute93
DATABASE_URL=postgresql://postgres:dev@localhost:5432/minute93

# ===== Authentication =====
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ===== API-Football =====
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Active leagues (comma-separated API-Football league IDs)
# PL=39, La Liga=140, Champions League=2, World Cup=1
ACTIVE_LEAGUES=39,140,2

# Polling intervals (milliseconds)
POLL_INTERVAL_LIVE=30000
POLL_INTERVAL_IDLE=300000

# ===== Redis =====
# Local: docker compose provides redis:7 on port 6379
# Production: Render Key Value internal URL
REDIS_URL=redis://localhost:6379

# ===== Kafka (Redpanda) =====
# Local: docker compose provides Redpanda on port 19092
# Production: Redpanda Cloud with SASL/SSL
KAFKA_BROKERS=localhost:19092
KAFKA_TOPIC=match.events
# Production only — leave unset for local dev:
# KAFKA_SSL=true
# KAFKA_SASL_USERNAME=your-redpanda-username
# KAFKA_SASL_PASSWORD=your-redpanda-password

# ===== Rate Limiting =====
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL=900000
AUTH_THROTTLE_LIMIT=3

# ===== IP Geolocation =====
IP_GEOLOCATION_URL=http://ip-api.com/json

# ===== Grafana Cloud (Phase 4) =====
# PROMETHEUS_REMOTE_WRITE_URL=https://prometheus-prod.grafana.net/api/prom/push
# GRAFANA_API_KEY=your-grafana-api-key
# GRAFANA_CLOUD_URL=https://yourname.grafana.net

# ===== Frontend URL (for CORS) =====
CLIENT_URL=http://localhost:3001
